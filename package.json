{
  "name": "egitim-galaksisi-monorepo",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "micro-frontends/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@egitim-galaksisi/web",
    "dev:teacher": "turbo run dev --filter=@egitim-galaksisi/teacher",
    "dev:admin": "turbo run dev --filter=@egitim-galaksisi/admin",
    "dev:math-games": "turbo run dev --filter=@egitim-galaksisi/math-games",
    "dev:logic-games": "turbo run dev --filter=@egitim-galaksisi/logic-games",
    "dev:language-games": "turbo run dev --filter=@egitim-galaksisi/language-games",
    "dev:all-apps": "turbo run dev --filter='./apps/*'",
    "dev:all-mfe": "turbo run dev --filter='./micro-frontends/*'",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:mfe": "turbo run build --filter='./micro-frontends/*'",
    "build:web": "turbo run build --filter=@egitim-galaksisi/web",
    "build:teacher": "turbo run build --filter=@egitim-galaksisi/teacher",
    "build:admin": "turbo run build --filter=@egitim-galaksisi/admin",
    "build:math-games": "turbo run build --filter=@egitim-galaksisi/math-games",
    "build:logic-games": "turbo run build --filter=@egitim-galaksisi/logic-games",
    "build:language-games": "turbo run build --filter=@egitim-galaksisi/language-games",
    "preview": "turbo run preview --filter=@egitim-galaksisi/web",
    "preview:web": "turbo run preview --filter=@egitim-galaksisi/web",
    "preview:teacher": "turbo run preview --filter=@egitim-galaksisi/teacher",
    "preview:admin": "turbo run preview --filter=@egitim-galaksisi/admin",
    "preview:math-games": "turbo run preview --filter=@egitim-galaksisi/math-games",
    "preview:logic-games": "turbo run preview --filter=@egitim-galaksisi/logic-games",
    "preview:language-games": "turbo run preview --filter=@egitim-galaksisi/language-games",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:property": "turbo run test:property",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:watch": "vitest watch",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chess.js": "^1.4.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.3",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fast-check": "^3.15.0",
    "playwright": "^1.40.0",
    "prettier": "^3.1.0",
    "turbo": "^2.3.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^1.0.0"
  },
  "packageManager": "npm@10.2.4"
}
